#!/usr/bin/env bash
# Manual push helper. Stage, commit with message, push.
# Usage: dotfiles-push "commit message"

set -euo pipefail

REPO="${DOTFILES_DIR:-$HOME/dotfiles}"
cd "$REPO"

if [ -z "$(git status --porcelain)" ]; then
  echo "nothing to commit"
  exit 0
fi

MSG="${1:-}"
if [ -z "$MSG" ]; then
  echo "usage: dotfiles-push \"message\"" >&2
  exit 1
fi

git add -A
git commit -m "$MSG"
git push origin main
